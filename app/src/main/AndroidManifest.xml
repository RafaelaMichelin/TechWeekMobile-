<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.TechWeekMobile">

        <activity
            android:name=".ui.MainActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity
            android:name=".ui.CadastroActivity"
            android:exported="false" />

        <activity
            android:name=".ui.CheckInActivity"
            android:exported="false" />

        <activity
            android:name=".ui.ProgramacaoActivity"
            android:exported="false" />

        <activity
            android:name=".ui.PalestrantesActivity"
            android:exported="false" />

        <activity
            android:name=".ui.FaqActivity"
            android:exported="false" />

        <activity
            android:name=".ui.LocalizacaoActivity"
            android:exported="false" />

        <activity
            android:name=".ui.AdminActivity"
            android:exported="false" />
    </application>

</manifest>
